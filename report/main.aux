\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}NCC baseline}{3}{subsection.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces NCC curves of \texttt  {cam1}, \texttt  {cam2}, and \texttt  {cam3} against \texttt  {cam0}. Each curve peaks at $\tau = 0$ and falls to baseline by $\tau = \pm 5$ frames. The peak heights of 0.55--0.63 reflect the fact that no single constant shift aligns the start and end of the recording simultaneously; this is the constant-$\tau $ model failing on linearly drifting data rather than a benign amplitude mismatch.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:sync}{{2}{3}{NCC curves of \cam {1}, \cam {2}, and \cam {3} against \cam {0}. Each curve peaks at $\tau = 0$ and falls to baseline by $\tau = \pm 5$ frames. The peak heights of 0.55--0.63 reflect the fact that no single constant shift aligns the start and end of the recording simultaneously; this is the constant-$\tau $ model failing on linearly drifting data rather than a benign amplitude mismatch}{figure.2}{}}
\newlabel{eq:ncc}{{1}{3}{NCC baseline}{equation.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Event-anchored affine model}{3}{subsection.4.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Frame indices of two manually-identified board-impact events across the four cameras. Both events are sub-frame in their natural duration (the board makes contact with the surface in a single sampled instant), so the readings are precise to within $\pm 1$ frame.}}{4}{table.4}\protected@file@percent }
\newlabel{tab:events}{{4}{4}{Frame indices of two manually-identified board-impact events across the four cameras. Both events are sub-frame in their natural duration (the board makes contact with the surface in a single sampled instant), so the readings are precise to within $\pm 1$ frame}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Two-event affine sync fit. $\beta $ is the per-frame clock ratio, and ``implied $f$'' converts back to an absolute frame rate by $\beta \cdot f_0$. The fitted rates differ from the metadata values in the third decimal, with \texttt  {cam3} the most extreme: 24.17~fps empirically versus 24.30~fps in metadata.}}{4}{table.5}\protected@file@percent }
\newlabel{tab:sync-fit}{{5}{4}{Two-event affine sync fit. $\beta $ is the per-frame clock ratio, and ``implied $f$'' converts back to an absolute frame rate by $\beta \cdot f_0$. The fitted rates differ from the metadata values in the third decimal, with \cam {3} the most extreme: 24.17~fps empirically versus 24.30~fps in metadata}{table.5}{}}
\newlabel{eq:affine-sync}{{2}{4}{Event-anchored affine model}{equation.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Predicted matched support-camera frame and offset $M_c(N) - N$ at six representative \texttt  {cam0} frames. The offset is small near both events (the fit is exact at the events themselves) and grows toward the ends of the recording. \texttt  {cam1} stays close to \texttt  {cam0} throughout; \texttt  {cam3} drifts by 142 frames (5.8~s) by frame 10\,000.}}{4}{table.6}\protected@file@percent }
\newlabel{tab:sync-drift}{{6}{4}{Predicted matched support-camera frame and offset $M_c(N) - N$ at six representative \cam {0} frames. The offset is small near both events (the fit is exact at the events themselves) and grows toward the ends of the recording. \cam {1} stays close to \cam {0} throughout; \cam {3} drifts by 142 frames (5.8~s) by frame 10\,000}{table.6}{}}
